.3577\n","\n"]}],"source":["from tqdm.auto import tqdm # Import progress bar\n","\n","# 1. Setup Loss and Optimizer\n","criterion = nn.NLLLoss()\n","optimizer = optim.Adam(model.fc.parameters(), lr=0.001)\n","\n","# 2. History dictionary\n","history = {'train_loss': [], 'val_loss': [], 'train_acc': [], 'val_acc': []}\n","\n","def run_epoch(epoch, epochs):\n","    # --- TRAINING PHASE ---\n","    model.train()\n","    train_loss, train_correct = 0.0, 0\n","\n","    # Wrap train_loader with tqdm for a live progress bar\n","    train_pbar = tqdm(train_loader, desc=f\"Epoch {epoch+1}/{epochs} [TRAIN]\", unit=\"batch\")\n","\n","    for images, labels in train_pbar:\n","        images, labels = images.to(device), labels.to(device)\n","\n","        optimizer.zero_grad()\n","        outputs = model(images)\n","        loss = criterion(outputs, labels)\n","        loss.backward()\n","        optimizer.step()\n","\n","        # Stats update\n","        batch_loss = loss.item()\n","        train_loss += batch_loss * images.size(0)\n","        _, preds = torch.max(outputs, 1)\n","        train_correct += torch.sum(preds == labels.data)\n","\n","        # Update the progress bar text with current batch loss\n","        train_pbar.set_postfix(loss=f\"{batch_loss:.4f}\")\n","\n","    # --- VALIDATION PHASE ---\n","    model.eval()\n","    val_loss, val_correct = 0.0, 0\n","\n","    # Wrap valid_loader with tqdm\n","    val_pbar = tqdm(valid_loader, desc=f\"Epoch {epoch+1}/{epochs} [VALID]\", unit=\"batch\")\n","\n","    with torch.no_grad():\n","        for images, labels in val_pbar:\n","            images, labels = images.to(device), labels.to(device)\n","            outputs = model(images)\n","            loss = criterion(outputs, labels)\n","\n","            val_loss += loss.item() * images.size(0)\n","            _, preds = torch.max(outputs, 1)\n","            val_correct += torch.sum(preds == labels.data)\n","\n","    # 3. Calculate Final Epoch Metrics\n","    t_loss = train_loss / len(train_ds)\n","    v_loss = val_loss / len(valid_ds)\n","    t_acc = train_correct.double() / len(train_ds)\n","    v_acc = val_correct.double() / len(valid_ds)\n","\n","    history['train_loss'].append(t_loss)\n","    history['val_loss'].append(v_loss)\n","    history['train_acc'].append(t_acc.cpu().item())\n","    history['val_acc'].append(v_acc.cpu().item())\n","\n","    # Final print for the epoch\n","    print(f\"\\nFINISH Epoch {epoch+1} -> Train Acc: {t_acc:.4f} | Val Acc: {v_acc:.4f} | Val Loss: {v_loss:.4f}\\n\")\n","\n","# 4. Main Execution Loop\n","print(\"Starting Training...\")\n","for e in range(3):\n","    run_epoch(e, 3)"]},{"cell_type":"markdown","metadata":{"id":"N2jNpJzy3zno"},"source":["## Validation Graph and Predictions\n","After training, we visualize the results and test the model on a single image."]},{"cell_type":"code","execution_count":null,"metadata":{"id":"WVBAwpxj3zno","colab":{"base_uri":"https://localhost:8080/","height":330},"executionInfo":{"status":"ok","timestamp":1779257492910,"user_tz":420,"elapsed":40566,"user":{"displayName":"Samit Goswami","userId":"14475250480982681095"}},"outputId":"8b425cd1-6c87-48ec-c28d-588f4724274f"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x400 with 2 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["\n","# --- PLOT GRAPH ---\n","plt.figure(figsize=(12, 4))\n","\n","# Subplot 1: Accuracy\n","plt.subplot(1, 2, 1)\n","plt.plot(history['train_acc'], label='Train Accuracy', color='blue')\n","plt.plot(history['val_acc'], label='Val Accuracy', color='orange')\n","plt.title('Accuracy over Epochs')\n","plt.xlabel('Epochs')\n","plt.ylabel('Accuracy')\n","plt.legend()\n","\n","# Subplot 2: Loss\n","plt.subplot(1, 2, 2)\n","plt.plot(history['train_loss'], label='Train Loss', color='blue')\n","plt.plot(history['val_loss'], label='Val Loss', color='orange')\n","plt.title('Loss over Epochs')\n","plt.xlabel('Epochs')\n","plt.ylabel('Loss')\n","plt.legend()\n","\n","plt.tight_layout() # Prevents labels from overlapping\n","plt.show()\n"]},{"cell_type":"markdown","metadata":{"id":"OADGdMlg3znp"},"source":["## Prediction Function"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"Z4SoLQmV3znp","colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"status":"ok","timestamp":1779257494634,"user_tz":420,"elapsed":1717,"user":{"displayName":"Samit Goswami","userId":"14475250480982681095"}},"outputId":"4e87ec49-4864-4ce9-9000-77916caf0975"},"outputs":[{"output_type":"stream","name":"stdout","text":["Prediction: fake (99.95% confidence)\n"]},{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/torch/nn/modules/module.py:1867: FutureWarning: Using a non-full backward hook when the forward contains multiple autograd Nodes is deprecated and will be removed in future versions. This hook will be missing some grad_input. Please use register_full_backward_hook to get the documented behavior.\n","  self._maybe_warn_non_full_backward_hook(args, result, grad_fn)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Prediction: real (80.87% confidence)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 2 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["import numpy as np\n","import cv2 # OpenCV for image processing, resizing, and colormapping\n","import matplotlib.pyplot as plt\n","\n","def predict_image(image_path):\n","    from PIL import Image\n","    import torch.nn.functional as F\n","\n","    # 1. Prepare Model\n","    model.eval()\n","\n","    # 2. Load and Preprocess Image\n","    img_pil = Image.open(image_path).convert('RGB') # Original PIL image for display\n","    img_t = transform(img_pil).unsqueeze(0).to(device) # Add batch dimension & move to GPU\n","\n","    # --- First pass for prediction (no_grad is fine here) ---\n","    with torch.no_grad():\n","        output_for_prediction = model(img_t)\n","\n","    probs = F.softmax(output_for_prediction, dim=1)\n","    conf, predicted = torch.max(probs, 1)\n","\n","    label = class_names[predicted.item()]\n","    confidence = conf.item() * 100\n","\n","    print(f\"Prediction: {label} ({confidence:.2f}% confidence)\")\n","\n","    # --- Grad-CAM Implementation for Visual Explanation ---\n","    model.zero_grad() # Clear gradients from previous ops\n","\n","    # Define variables to store activations and gradients\n","    activations = None\n","    gradients = None\n","\n","    # Hook function to capture activations (output of target_layer)\n","    def save_activations(module, input, output):\n","        nonlocal activations\n","        activations = output\n","\n","    # Hook function to capture gradients (gradients flowing back into the output of target_layer)\n","    def save_gradients(module, grad_input, grad_output):\n","        nonlocal gradients\n","        gradients = grad_output[0] # grad_output[0] is the gradient for the output of the module\n","\n","    # Register hooks to the last convolutional layer. For ResNet18, this is typically in layer4.\n","    # We choose the 'conv2' layer of the last BasicBlock in layer4.\n","    target_layer = model.layer4[-1].conv2\n","\n","    # --- Temporarily unfreeze target_layer for Grad-CAM computation ---\n","    original_target_layer_requires_grad_state = {}\n","    for param_name, param in target_layer.named_parameters():\n","        original_target_layer_requires_grad_state[param_name] = param.requires_grad\n","        param.requires_grad_(True) # Temporarily enable gradients\n","\n","    # Ensure the input image explicitly requires gradients for backprop through conv layers.\n","    img_t.requires_grad_(True)\n","\n","    hook_handle_activations = target_layer.register_forward_hook(save_activations)\n","    hook_handle_gradients = target_layer.register_backward_hook(save_gradients)\n","\n","    # Perform a forward pass *without* torch.no_grad() for Grad-CAM\n","    # This ensures the computational graph is built and gradients can be tracked.\n","    output_for_grad = model(img_t)\n","\n","    # Get the score for the predicted class\n","    predicted_class_score = output_for_grad[:, predicted.item()]\n","\n","    # Perform a backward pass to get gradients\n","    predicted_class_score.backward(retain_graph=False)\n","\n","    # Remove hooks\n","    hook_handle_activations.remove()\n","    hook_handle_gradients.remove()\n","\n","    # --- Re-freeze target_layer after Grad-CAM computation ---\n","    for param_name, param in target_layer.named_parameters():\n","        param.requires_grad_(original_target_layer_requires_grad_state[param_name])\n","\n","    # Detach tensors and move to CPU for NumPy operations\n","    # Now 'activations' and 'gradients' should have values\n","    if activations is None or gradients is None:\n","        print(\"Error: Activations or gradients were not captured. Grad-CAM cannot be performed.\")\n","        plt.figure(figsize=(6, 6))\n","        plt.imshow(img_pil)\n","        plt.title(f\"Original: {label} ({confidence:.2f}%) (Grad-CAM failed)\")\n","        plt.axis('off')\n","        plt.show()\n","        return\n","\n","    activations_np = activations.detach().cpu().numpy()\n","    gradients_np = gradients.detach().cpu().numpy()\n","\n","    # Global average pooling of gradients to get weights for each channel\n","    weights = np.mean(gradients_np, axis=(2, 3))[0, :]\n","\n","    # Create heatmap: sum of (weights * activations)\n","    heatmap = np.zeros(activations_np.shape[2:], dtype=np.float32)\n","    for i, w in enumerate(weights):\n","        heatmap += w * activations_np[0, i, :, :]\n","\n","    # Apply ReLU to keep only positive contributions (features that positively influence the prediction)\n","    heatmap = np.maximum(heatmap, 0)\n","\n","    # Normalize heatmap\n","    if np.max(heatmap) > 0:\n","        heatmap /= np.max(heatmap)\n","    else:\n","        heatmap = np.zeros_like(heatmap) # Handle case where heatmap is all zeros\n","\n","    # Resize heatmap to original image size\n","    heatmap = cv2.resize(heatmap, (img_pil.width, img_pil.height))\n","\n","    # Convert heatmap to a color image and overlay on the original image\n","    heatmap = np.uint8(255 * heatmap)\n","    heatmap = cv2.applyColorMap(heatmap, cv2.COLORMAP_JET) # Apply JET colormap\n","    heatmap = cv2.cvtColor(heatmap, cv2.COLOR_BGR2RGB) # Convert BGR from OpenCV to RGB for Matplotlib\n","\n","    # Convert PIL image to NumPy array for OpenCV blending\n","    img_np = np.array(img_pil)\n","    overlayed_img = cv2.addWeighted(img_np, 0.7, heatmap, 0.3, 0) # Blend original image with heatmap\n","\n","    # 4. Display Results with Grad-CAM\n","    plt.figure(figsize=(12, 6))\n","\n","    plt.subplot(1, 2, 1)\n","    plt.imshow(img_pil)\n","    plt.title(f\"Original: {label} ({confidence:.2f}%)\")\n","    plt.axis('off')\n","\n","    plt.subplot(1, 2, 2)\n","    plt.imshow(overlayed_img)\n","    plt.title(f\"Grad-CAM: {label} (Model's Focus)\") # Indicates regions that influenced the prediction\n","    plt.axis('off')\n","\n","    plt.tight_layout()\n","    plt.show() # Forces the image to display\n","\n","# --- HOW TO FIND A PATH ON KAGGLE ---\n","# Since you have the dataset from your image, try this path:\n","test_image_path0 = '/kaggle/input/140k-real-and-fake-faces/real_vs_fake/real-vs-fake/test/fake/008BYSE725.jpg'\n","test_image_path1 = '/kaggle/input/140k-real-and-fake-faces/real_vs_fake/real-vs-fake/test/real/00007.jpg'\n","# Run the prediction\n","predict_image(test_image_path0) # This is a fake image check whats the prdection\n","predict_image(test_image_path1) # This is a real image check whats the prdection"]},{"cell_type":"markdown","metadata":{"id":"1yLGrAuQ3znp"},"source":["## Save Model"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"0cw8