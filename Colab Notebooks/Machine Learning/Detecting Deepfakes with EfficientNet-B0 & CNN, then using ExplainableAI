ased on folder names)\n","train_ds = datasets.ImageFolder(os.path.join(data_dir, 'train'), transform=transform)\n","valid_ds = datasets.ImageFolder(os.path.join(data_dir, 'valid'), transform=transform)\n","\n","# DataLoaders handle shuffling and batching images for the GPU\n","train_loader = DataLoader(train_ds, batch_size=128, shuffle=True, num_workers=2, pin_memory=True)\n","valid_loader = DataLoader(valid_ds, batch_size=128, shuffle=False, num_workers=2, pin_memory=True) # no need to shuffel Validation data\n","\n","print(f\"Training images: {len(train_ds)} | Validation images: {len(valid_ds)}\")\n","\n","# Get Class Information\n","class_names = train_ds.classes\n","num_classes = len(class_names)\n","print(f\"Detected {num_classes} classes: {class_names}\")"],"metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-01-14T20:11:38.846059Z","iopub.execute_input":"2026-01-14T20:11:38.846329Z","iopub.status.idle":"2026-01-14T20:12:11.764996Z","shell.execute_reply.started":"2026-01-14T20:11:38.846299Z","shell.execute_reply":"2026-01-14T20:12:11.764252Z"},"id":"-A_kLlqF3znm","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1779281434994,"user_tz":420,"elapsed":153274,"user":{"displayName":"Samit Goswami","userId":"14475250480982681095"}},"outputId":"1621cd5b-8a76-4080-b53e-1e51a598ef42"},"outputs":[{"output_type":"stream","name":"stdout","text":["Training images: 100000 | Validation images: 20000\n","Detected 2 classes: ['fake', 'real']\n"]}],"execution_count":null},{"cell_type":"markdown","source":["## Model Architecture\n","We use **Transfer Learning**. Instead of building a model from scratch, we use **EfficientNet-B0**, which already \"knows\" how to recognize shapes and textures. We simply replace the final layer to output a \"Real\" or \"Fake\" prediction."],"metadata":{"id":"m6ALz_VT3znn"}},{"cell_type":"code","source":[],"metadata":{"id":"7RCXsnCZkKnp"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import torch.nn as nn\n","\n","# Load a pre-trained EfficientNet-B0 model\n","# Use 'weights=models.EfficientNet_B0_Weights.IMAGENET1K_V1' for pre-trained weights\n","model = models.efficientnet_b0(weights=models.EfficientNet_B0_Weights.IMAGENET1K_V1)\n","\n","# Freeze all layers so we don't destroy the pre-trained weights during initial training\n","for param in model.parameters():\n","    param.requires_grad = False\n","\n","# Replace the classifier layer (EfficientNet uses 'classifier' instead of 'fc')\n","# EfficientNet-B0's classifier is a sequential block, and the last layer is a linear layer.\n","# The input features for this linear layer determine num_ftrs.\n","num_ftrs = model.classifier[1].in_features\n","model.classifier = nn.Sequential(\n","    nn.Dropout(p=0.2, inplace=True), # Keep original dropout rate\n","    nn.Linear(num_ftrs, 256), # First custom linear layer\n","    nn.ReLU(),\n","    nn.Dropout(0.4), # Custom dropout rate\n","    nn.Linear(256, 2), # Output layer: 2 classes (Real vs Fake)\n","    nn.LogSoftmax(dim=1) # Better for numerical stability\n",")\n","\n","model = model.to(device)"],"metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-01-14T20:12:11.766663Z","iopub.execute_input":"2026-01-14T20:12:11.766965Z","iopub.status.idle":"2026-01-14T20:12:11.973051Z","shell.execute_reply.started":"2026-01-14T20:12:11.766929Z","shell.execute_reply":"2026-01-14T20:12:11.972284Z"},"id":"CxpwQ4o73znn","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1779281435708,"user_tz":420,"elapsed":704,"user":{"displayName":"Samit Goswami","userId":"14475250480982681095"}},"outputId":"b2138b84-fdcd-4193-fa74-09beeb749b54"},"outputs":[{"output_type":"stream","name":"stdout","text":["Downloading: \"https://download.pytorch.org/models/efficientnet_b0_rwightman-7f5810bc.pth\" to /root/.cache/torch/hub/checkpoints/efficientnet_b0_rwightman-7f5810bc.pth\n"]},{"output_type":"stream","name":"stderr","text":["100%|██████████| 20.5M/20.5M [00:00<00:00, 151MB/s]\n"]}],"execution_count":null},{"cell_type":"markdown","source":["## Training Loop with Scoring and Validation\n","This loop tracks both Training and Validation scores to help you identify if the model is overfitting."],"metadata":{"id":"N-ln6_Ls3zno"}},{"cell_type":"code","source":["from tqdm.auto import tqdm # Import progress bar\n","\n","# 1. Setup Loss and Optimizer\n","criterion = nn.NLLLoss()\n","optimizer = optim.Adam(model.classifier.parameters(), lr=0.001)\n","\n","# 2. History dictionary\n","history = {'train_loss': [], 'val_loss': [], 'train_acc': [], 'val_acc': []}\n","\n","def run_epoch(epoch, epochs):\n","    # --- TRAINING PHASE ---\n","    model.train()\n","    train_loss, train_correct = 0.0, 0\n","\n","    # Wrap train_loader with tqdm for a live progress bar\n","    train_pbar = tqdm(train_loader, desc=f\"Epoch {epoch+1}/{epochs} [TRAIN]\", unit=\"batch\")\n","\n","    for images, labels in train_pbar:\n","        images, labels = images.to(device), labels.to(device)\n","\n","        optimizer.zero_grad()\n","        outputs = model(images)\n","        loss = criterion(outputs, labels)\n","        loss.backward()\n","        optimizer.step()\n","\n","        # Stats update\n","        batch_loss = loss.item()\n","        train_loss += batch_loss * images.size(0)\n","        _, preds = torch.max(outputs, 1)\n","        train_correct += torch.sum(preds == labels.data)\n","\n","        # Update the progress bar text with current batch loss\n","        train_pbar.set_postfix(loss=f\"{batch_loss:.4f}\")\n","\n","    # --- VALIDATION PHASE ---\n","    model.eval()\n","    val_loss, val_correct = 0.0, 0\n","\n","    # Wrap valid_loader with tqdm\n","    val_pbar = tqdm(valid_loader, desc=f\"Epoch {epoch+1}/{epochs} [VALID]\", unit=\"batch\")\n","\n","    with torch.no_grad():\n","        for images, labels in val_pbar:\n","            images, labels = images.to(device), labels.to(device)\n","            outputs = model(images)\n","            loss = criterion(outputs, labels)\n","\n","            val_loss += loss.item() * images.size(0)\n","            _, preds = torch.max(outputs, 1)\n","            val_correct += torch.sum(preds == labels.data)\n","\n","    # 3. Calculate Final Epoch Metrics\n","    t_loss = train_loss / len(train_ds)\n","    v_loss = val_loss / len(valid_ds)\n","    t_acc = train_correct.double() / len(train_ds)\n","    v_acc = val_correct.double() / len(valid_ds)\n","\n","    history['train_loss'].append(t_loss)\n","    history['val_loss'].append(v_loss)\n","    history['train_acc'].append(t_acc.cpu().item())\n","    history['val_acc'].append(v_acc.cpu().item())\n","\n","    # Final print for the epoch\n","    print(f\"\\nFINISH Epoch {epoch+1} -> Train Acc: {t_acc:.4f} | Val Acc: {v_acc:.4f} | Val Loss: {v_loss:.4f}\\n\")\n","\n","# 4. Main Execution Loop\n","print(\"Starting Training...\")\n","for e in range(3):\n","    run_epoch(e, 3)"],"metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-01-14T20:12:11.974046Z","iopub.execute_input":"2026-01-14T20:12:11.97432Z","iopub.status.idle":"2026-01-14T20:21:28.738373Z","shell.execute_reply.started":"2026-01-14T20:12:11.97429Z","shell.execute_reply":"2026-01-14T20:21:28.737318Z"},"id":"H_IZO6yd3zno","colab":{"base_uri":"https://localhost:8080/","height":1000,"referenced_widgets":["5cfdf51692e54dbe8eeb6f3f62071f18","87221e5ff7fd4d8f96419f84f536e6de","12472564cc1b4cfdb058558769688265","5c494edf8a30433a8a0f14ed5344e159","a4398d37ebf2491b98eb6269c60d61ae","86d1f59be1114726b9793bc2b441a78a","5cd81b27e10049e3ad16dd16e34c4240","2fb2bfee99af48cb8ef8461648fff101","9685362b0aa94ae088e22d404a25ab1c","6d52e9522c21405796f16689b045e416","2ca4237f807647e9a38cb4f2921740e6","c8b584b25472430cb014f6e6c0fc85de","ef7c4e2c16594cef8ffac61a9e382b9e","82aa3ba7f2014fb1be5ddbe878350e90","dc5cfb93cff74b7aa47af42fb138810b","43d117077d3c4046af9026c85b10a370","e306ed2ca18146df97301487c9a577e6","a81b4c628a094643862f6