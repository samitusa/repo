_type":"code","source":["import numpy as np\n","import cv2 # OpenCV for image processing, resizing, and colormapping\n","import matplotlib.pyplot as plt\n","\n","def predict_image(image_path):\n","    from PIL import Image\n","    import torch.nn.functional as F\n","\n","    # 1. Prepare Model\n","    model.eval()\n","\n","    # 2. Load and Preprocess Image\n","    img_pil = Image.open(image_path).convert('RGB') # Original PIL image for display\n","    img_t = transform(img_pil).unsqueeze(0).to(device) # Add batch dimension & move to GPU\n","\n","    # --- First pass for prediction (no_grad is fine here) ---\n","    with torch.no_grad():\n","        output_for_prediction = model(img_t)\n","\n","    probs = F.softmax(output_for_prediction, dim=1)\n","    conf, predicted = torch.max(probs, 1)\n","\n","    label = class_names[predicted.item()]\n","    confidence = conf.item() * 100\n","\n","    print(f\"Prediction: {label} ({confidence:.2f}% confidence)\")\n","\n","    # --- Grad-CAM Implementation for Visual Explanation ---\n","    model.zero_grad() # Clear gradients from previous ops\n","\n","    # Define variables to store activations and gradients\n","    activations = None\n","    gradients = None\n","\n","    # Hook function to capture activations (output of target_layer)\n","    def save_activations(module, input, output):\n","        nonlocal activations\n","        activations = output\n","\n","    # Hook function to capture gradients (gradients flowing back into the output of target_layer)\n","    def save_gradients(module, grad_input, grad_output):\n","        nonlocal gradients\n","        gradients = grad_output[0] # grad_output[0] is the gradient for the output of the module\n","\n","    # For EfficientNet-B0, a good target layer for Grad-CAM is typically the last convolutional block in features.\n","    # EfficientNet's features are a sequential block. We want the last convolutional layer before the classifier.\n","    # model.features[-1] refers to the last block of features.\n","    # Inside this block, there are several layers. We'll pick the last Conv2d layer.\n","    # Iterating through the children of the last block to find the last Conv2d layer.\n","    target_layer = None\n","    # Convert the generator to a list before reversing\n","    for module in reversed(list(model.features[-1].modules())):\n","        if isinstance(module, nn.Conv2d):\n","            target_layer = module\n","            break\n","\n","    if target_layer is None:\n","        print(\"Error: Could not find a suitable convolutional target layer for Grad-CAM.\")\n","        plt.figure(figsize=(6, 6))\n","        plt.imshow(img_pil)\n","        plt.title(f\"Original: {label} ({confidence:.2f}%) (Grad-CAM failed)\")\n","        plt.axis('off')\n","        plt.show()\n","        return\n","\n","    # --- Temporarily unfreeze target_layer for Grad-CAM computation ---\n","    original_target_layer_requires_grad_state = {}\n","    for param_name, param in target_layer.named_parameters():\n","        original_target_layer_requires_grad_state[param_name] = param.requires_grad\n","        param.requires_grad_(True) # Temporarily enable gradients\n","\n","    # Ensure the input image explicitly requires gradients for backprop through conv layers.\n","    img_t.requires_grad_(True)\n","\n","    hook_handle_activations = target_layer.register_forward_hook(save_activations)\n","    hook_handle_gradients = target_layer.register_backward_hook(save_gradients)\n","\n","    # Perform a forward pass *without* torch.no_grad() for Grad-CAM\n","    # This ensures the computational graph is built and gradients can be tracked.\n","    output_for_grad = model(img_t)\n","\n","    # Get the score for the predicted class\n","    predicted_class_score = output_for_grad[:, predicted.item()]\n","\n","    # Perform a backward pass to get gradients\n","    predicted_class_score.backward(retain_graph=False)\n","\n","    # Remove hooks\n","    hook_handle_activations.remove()\n","    hook_handle_gradients.remove()\n","\n","    # --- Re-freeze target_layer after Grad-CAM computation ---\n","    for param_name, param in target_layer.named_parameters():\n","        param.requires_grad_(original_target_layer_requires_grad_state[param_name])\n","\n","    # Detach tensors and move to CPU for NumPy operations\n","    # Now 'activations' and 'gradients' should have values\n","    if activations is None or gradients is None:\n","        print(\"Error: Activations or gradients were not captured. Grad-CAM cannot be performed.\")\n","        plt.figure(figsize=(6, 6))\n","        plt.imshow(img_pil)\n","        plt.title(f\"Original: {label} ({confidence:.2f}%) (Grad-CAM failed)\")\n","        plt.axis('off')\n","        plt.show()\n","        return\n","\n","    activations_np = activations.detach().cpu().numpy()\n","    gradients_np = gradients.detach().cpu().numpy()\n","\n","    # Global average pooling of gradients to get weights for each channel\n","    weights = np.mean(gradients_np, axis=(2, 3))[0, :]\n","\n","    # Create heatmap: sum of (weights * activations)\n","    heatmap = np.zeros(activations_np.shape[2:], dtype=np.float32)\n","    for i, w in enumerate(weights):\n","        heatmap += w * activations_np[0, i, :, :]\n","\n","    # Apply ReLU to keep only positive contributions (features that positively influence the prediction)\n","    heatmap = np.maximum(heatmap, 0)\n","\n","    # Normalize heatmap\n","    if np.max(heatmap) > 0:\n","        heatmap /= np.max(heatmap)\n","    else:\n","        heatmap = np.zeros_like(heatmap) # Handle case where heatmap is all zeros\n","\n","    # Resize heatmap to original image size\n","    heatmap = cv2.resize(heatmap, (img_pil.width, img_pil.height))\n","\n","    # Convert heatmap to a color image and overlay on the original image\n","    heatmap = np.uint8(255 * heatmap)\n","    heatmap = cv2.applyColorMap(heatmap, cv2.COLORMAP_JET) # Apply JET colormap\n","    heatmap = cv2.cvtColor(heatmap, cv2.COLOR_BGR2RGB) # Convert BGR from OpenCV to RGB for Matplotlib\n","\n","    # Convert PIL image to NumPy array for OpenCV blending\n","    img_np = np.array(img_pil)\n","    overlayed_img = cv2.addWeighted(img_np, 0.7, heatmap, 0.3, 0) # Blend original image with heatmap\n","\n","    # 4. Display Results with Grad-CAM\n","    plt.figure(figsize=(12, 6))\n","\n","    plt.subplot(1, 2, 1)\n","    plt.imshow(img_pil)\n","    plt.title(f\"Original: {label} ({confidence:.2f}%)\")\n","    plt.axis('off')\n","\n","    plt.subplot(1, 2, 2)\n","    plt.imshow(overlayed_img)\n","    plt.title(f\"Grad-CAM: {label} (Model's Focus)\") # Indicates regions that influenced the prediction\n","    plt.axis('off')\n","\n","    plt.tight_layout()\n","    plt.show() # Forces the image to display\n","\n","# --- HOW TO FIND A PATH ON KAGGLE ---\n","# Since you have the dataset from your image, try this path:\n","test_image_path0 = '/kaggle/input/140k-real-and-fake-faces/real_vs_fake/real-vs-fake/test/fake/008BYSE725.jpg'\n","test_image_path1 = '/kaggle/input/140k-real-and-fake-faces/real_vs_fake/real-vs-fake/test/real/00007.jpg'\n","# Run the prediction\n","predict_image(test_image_path0) # This is a fake image check whats the prdection\n","predict_image(test_image_path1) # This is a real image check whats the prdection"],"metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-01-14T20:29:59.19382Z","iopub.execute_input":"2026-01-14T20:29:59.194468Z","iopub.status.idle":"2026-01-14T20:29:59.483795Z","shell.execute_reply.started":"2026-01-14T20:29:59.194433Z","shell.execute_reply":"2026-01-14T20:29:59.483097Z"},"id":"Z4SoLQmV3znp","colab":{"base_uri":"https://localhost:8080/","height":974},"executionInfo":{"status":"ok","timestamp":1779282918346,"user_tz":420,"elapsed":1847,"user":{"displayName":"Samit Goswami","userId":"14475250480982681095"}},"outputId":"a5c9a1ff-c867-407a-ba8d-bf89d6c6bc6e"},"outputs":[{"output_type":"stream","name":"stdout","text":["Prediction: fake 